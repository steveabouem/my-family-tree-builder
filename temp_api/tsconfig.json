{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",            
    "paths": {
      "@/*": ["src/*"],
      "@models/*": ["./models/*"],
      "@services/*": ["./services/*"],
      "@routes/*": ["./routes/*"],
      "@utils/*": ["./utils/*"],
      "@config/*": ["./config/*"],
      "@migrations/*": ["./migrations/*"],
      "@seeders/*": ["./seeders/*"],
      // "@shared/*": ["../shared/*"], monorepo setup needs work (and vite)
    },
    "outDir": "./dist",
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}